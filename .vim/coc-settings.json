{
  "languageserver": {
    "typescript": {
      "command": "typescript-language-server",
      "args": ["--stdio"],
      "filetypes": ["typescript"]
    },
    "nix": {
      "command": "nixd",
      "filetypes": ["nix"]
    }
  },
  "coc.preferences.formatOnSaveFiletypes": ["nix", "typescript"]
}
